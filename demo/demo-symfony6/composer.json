{
    "name": "nowo-tech/login-throttle-demo-symfony6",
    "description": "Demo project for Login Throttle Bundle - Symfony 6.0",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "/var/login-throttle-bundle",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1,<8.3",
        "doctrine/doctrine-bundle": "^2.10",
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/migrations": "^3.6",
        "doctrine/orm": "^2.15",
        "nowo-tech/login-throttle-bundle": "^0.0",
        "symfony/console": "^6.0",
        "symfony/dotenv": "^6.0",
        "symfony/flex": "^2.0",
        "symfony/form": "^6.0",
        "symfony/framework-bundle": "^6.0",
        "symfony/runtime": "^6.0",
        "symfony/security-bundle": "^6.0",
        "symfony/translation": "6.*",
        "symfony/twig-bundle": "^6.0",
        "symfony/validator": "^6.0",
        "symfony/yaml": "^6.0"
    },
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "phpunit/phpunit": "^9.5 || ^10.0",
        "symfony/browser-kit": "6.0.*",
        "symfony/css-selector": "6.0.*",
        "symfony/debug-bundle": "6.*",
        "symfony/web-profiler-bundle": "6.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true,
        "audit": {
            "abandoned": "report"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage --coverage-clover coverage.xml",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "database": [
            "@php bin/console doctrine:database:create --if-not-exists",
            "@php bin/console doctrine:migrations:migrate --no-interaction",
            "@php bin/console doctrine:schema:update --force --complete",
            "@php bin/console doctrine:fixtures:load --no-interaction"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.*"
        }
    }
}
